# Local: disable SSL. Render + Supabase: use Connect → Session pooler (not Direct), e.g.:
# DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/daystack?sslmode=disable
PORT=8080
# In production, set this to your Vercel frontend URL to restrict CORS:
# ALLOWED_ORIGIN=https://your-app.vercel.app
